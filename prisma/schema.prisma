generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  googleId      String?   @unique
  createdAt     DateTime  @default(now())
  accounts      Account[]
  profiles      Profile[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String        @id @default(cuid())
  userId      String
  name        String
  avatarColor String        @default("#6366f1")
  avatarEmoji String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userContent UserContent[]

  @@index([userId])
}

model Content {
  id               String              @id @default(cuid())
  contentType      ContentType
  title            String
  originalTitle    String?
  year             Int?
  posterUrl        String?
  backdropUrl      String?
  overview         String?
  tagline          String?
  genres           Json                @default("[]")
  genreNames       String?
  runtimeMins      Int?
  status           String?
  tmdbId           Int?                @unique
  imdbId           String?
  malId            Int?                @unique
  tmdbRating       Decimal?            @db.Decimal(3, 1)
  tmdbVoteCount    Int?
  language         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  adult            Boolean?            @default(false)
  episodeRuntime   Int?
  episodes         Int?
  languages        Json                @default("[]")
  networks         Json                @default("[]")
  revenue          Float?
  seasons          Int?
  ageCertification String?
  omdbRatings      Json                @default("[]")
  enrichments      ContentEnrichment[]
  userContent      UserContent[]

  @@index([contentType])
  @@index([tmdbId])
  @@index([malId])
  @@index([tmdbRating(sort: Desc)])
  @@index([title])
  @@index([year(sort: Desc)])
  @@index([genreNames])
}

model ContentEnrichment {
  id        String   @id @default(cuid())
  contentId String
  source    String
  data      Json
  fetchedAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, source])
  @@index([contentId])
}

model UserContent {
  id           String      @id @default(cuid())
  profileId    String
  contentId    String
  listStatus   ListStatus  @default(WATCHED)
  userRating           Int?
  notes                String?
  recommendationReason String?
  recommendationLabel  RecommendationLabel?
  watchedDate          DateTime?   @db.Date
  watchStatus  WatchStatus?
  startDate    DateTime?   @db.Date
  endDate      DateTime?   @db.Date
  episodeCount Int?
  addedAt      DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  content      Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
  @@index([profileId, listStatus, addedAt(sort: Desc)])
  @@index([profileId, userRating(sort: Desc)])
  @@index([profileId, watchStatus])
  @@index([contentId])
}

enum ListStatus {
  RECOMMENDED
  PLANNED
  WATCHED
}

enum ContentType {
  MOVIE
  TV_SHOW
  ANIME
}

enum WatchStatus {
  WATCHING
  PLAN_TO_WATCH
  COMPLETED
  DROPPED
}

enum RecommendationLabel {
  UNDERRATED
  CRITICALLY_ACCLAIMED
  AWARD_WINNING
  FAN_FAVORITE
  CULT_CLASSIC
  VISUAL_SPECTACLE
  IMMERSIVE_SOUND
  TECHNICAL_MASTERY
  DIRECTORIAL_DEBUT
  GENRE_DEFINING
}
